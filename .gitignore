# Dependencies
node_modules/
node_modules copy/
frontend/node_modules/
mobile/node_modules/

# Environment — NEVER commit real keys
.env
.env.local
.env.production

# Logs
*.log
logs/
logs/pm2-out.log
logs/pm2-err.log
!logs/.gitkeep

# ── Runtime-generated data — self-initializing, never seed/config ──────────
# Every file under data/ is created and rewritten by backend/services/*State.cjs
# and agents/runtime/*.cjs modules with hardcoded defaults on first run. None of
# it ships as source. Ignore the whole tree instead of enumerating file-by-file.
data/
!data/.gitkeep

# Code-generation agent output (agents/dev/codeGeneratorAgent.cjs writes here)
generated/
!generated/.gitkeep

# Backups
backups/

# Legacy / junk
*.backup
*.save
dist/

# Frontend — build IS committed so VPS doesn't need npm
# frontend/build   ← intentionally NOT ignored

# OS

# Benchmark/Debug/Temp artifacts
temp_measure.js
measure_bottlenecks.js
validate_calmness.js
persistent_session.js
queue.json

# Test files and scripts
tests/
.DS_Store
Thumbs.db
_archive/
tests/legacy/
key.properties
ooplix-release.keystore
*.keystore
