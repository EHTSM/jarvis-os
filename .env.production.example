# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example — JARVIS OS Production Environment Template
#
# Copy to .env and fill in all REQUIRED values before starting the server.
# NEVER commit .env to git. Keep this file in source control.
#
# To generate OPERATOR_PASSWORD_HASH and JWT_SECRET run:
#   node scripts/generate-password-hash.cjs <your-password>
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED — Server will degrade or be inaccessible without these ───────────

# Operator auth — BOTH must be set or the console returns 503 on every request
JWT_SECRET=<generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
OPERATOR_PASSWORD_HASH=<generate: node scripts/generate-password-hash.cjs <password>>

# AI inference — GROQ_API_KEY is required for /jarvis and /ai/chat routes
GROQ_API_KEY=gsk_...

# ── REQUIRED — Runtime ────────────────────────────────────────────────────────

NODE_ENV=production
PORT=5050

# Public URL of this server — used for Razorpay webhook callback
# Without this, payment callbacks point to localhost and payments silently fail
BASE_URL=https://yourdomain.com

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com

# ── OPTIONAL — WhatsApp Business API ─────────────────────────────────────────
# Leave blank to disable WhatsApp. Server starts normally without these.
WA_TOKEN=EAAxxxx...
WA_PHONE_ID=12345678901234
WA_API_VERSION=v19.0
WA_VERIFY_TOKEN=your_verify_token_here
WA_BUSINESS_ACCOUNT_ID=

# Set to "true" to disable WhatsApp sends without removing credentials
DISABLE_WHATSAPP=false

# ── OPTIONAL — Telegram ───────────────────────────────────────────────────────
# Leave blank to disable the Telegram bot and /telegram/send route
TELEGRAM_TOKEN=123456:ABC-xxxx
TELEGRAM_CHAT_ID=

# ── OPTIONAL — Razorpay Payments ─────────────────────────────────────────────
# Leave blank to disable payment link creation
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Required for webhook HMAC verification in production — set in Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Set to "true" to disable payment link creation without removing credentials
DISABLE_PAYMENTS=false

# Fallback static payment link shown in Telegram bot if Razorpay API fails
PAYMENT_FALLBACK_LINK=https://rzp.io/l/your-link

# ── OPTIONAL — Google / Maps ──────────────────────────────────────────────────
GOOGLE_API=AIzaSy...

# ── OPTIONAL — OpenAI (legacy fallback) ──────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── OPTIONAL — LLM Provider override ─────────────────────────────────────────
LLM_PROVIDER=groq
