{
  "name": "jarvis-os",
  "version": "1.0.0-rc4",
  "description": "Ooplix — AI Operating System for Solo Founders & Small Teams by ALWALIY TECHNOLOGIES PRIVATE LIMITED",
  "main": "electron/main.cjs",
  "type": "commonjs",
  "scripts": {
    "start": "node scripts/check-startup-env.cjs && node backend/server.js",
    "frontend": "cd frontend && npm start",
    "desktop": "electron .",
    "dev": "concurrently \"npm start\" \"npm run frontend\"",
    "dev:full": "concurrently \"npm start\" \"npm run frontend\" \"npm run desktop\"",
    "build:frontend": "cd frontend && npm run build",
    "test:api": "curl -s -X POST http://localhost:5050/jarvis -H 'Content-Type: application/json' -d '{\"input\":\"hello\"}'",
    "test:runtime": "node --test tests/runtime/01-taskRouter.test.cjs tests/runtime/02-priorityQueue.test.cjs tests/runtime/03-executionHistory.test.cjs tests/runtime/04-agentRegistry.test.cjs tests/runtime/05-dispatch.test.cjs tests/runtime/06-retry.test.cjs tests/runtime/07-queue.test.cjs tests/runtime/08-terminal.test.cjs",
    "test:runtime:fast": "node --test tests/runtime/01-taskRouter.test.cjs tests/runtime/02-priorityQueue.test.cjs tests/runtime/03-executionHistory.test.cjs tests/runtime/04-agentRegistry.test.cjs",
    "test:stress": "node --test tests/stress/02-queue-pressure.test.cjs tests/stress/04-recovery-simulation.test.cjs && node --expose-gc --test tests/stress/03-memory-stability.test.cjs",
    "test:stress:http": "node --test tests/stress/01-http-stress.test.cjs",
    "test:burnin": "node tests/stress/05-burnin.cjs",
    "burnin": "node tests/burnin/run-burnin.cjs",
    "burnin:quick": "node tests/burnin/run-burnin.cjs --quick",
    "burnin:offline": "node tests/burnin/run-burnin.cjs --skip=02,03,04,05",
    "burnin:disk": "node tests/burnin/07-disk-monitor.cjs",
    "burnin:persistence": "node tests/burnin/06-persistence-recovery.cjs",
    "burnin:continuous": "node tests/burnin/01-continuous-runtime.cjs --quick",
    "burnin:monitor:8h": "node tests/burnin/01-continuous-runtime.cjs --minutes=480",
    "burnin:monitor:idle": "node tests/burnin/01-continuous-runtime.cjs --idle",
    "backup": "bash backup.sh",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:restart": "pm2 restart jarvis-os",
    "pm2:logs": "pm2 logs jarvis-os",
    "pm2:stop": "pm2 stop jarvis-os",
    "deploy:setup": "bash deploy/setup-vps.sh",
    "deploy:start": "bash deploy/start-production.sh",
    "deploy:update": "bash deploy/update.sh",
    "deploy:rollback": "bash deploy/rollback.sh",
    "security:no-raw-exec": "node scripts/check-no-raw-exec.cjs",
    "env:check": "node scripts/check-startup-env.cjs",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run frontend\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build:frontend && electron-builder",
    "dist:mac": "npm run build:frontend && electron-builder --mac --publish never",
    "dist:win": "npm run build:frontend && electron-builder --win --publish never",
    "dist:linux": "npm run build:frontend && electron-builder --linux --publish never",
    "dist:all": "npm run build:frontend && electron-builder --mac --win --linux --publish never",
    "dist:release": "npm run build:frontend && electron-builder --publish always",
    "rebuild": "electron-rebuild -f -w node-pty,better-sqlite3",
    "postinstall": "electron-builder install-app-deps || exit 0",
    "electron:smoke": "node scripts/electron-smoke-test.cjs"
  },
  "build": {
    "appId": "com.ooplix.jarvis",
    "productName": "Ooplix",
    "copyright": "Copyright © 2026 Ooplix",
    "files": [
      "electron/**/*",
      "frontend/build/**/*",
      "backend/**/*",
      "scripts/**/*",
      "package.json",
      "!**/.env",
      "!**/.env.*",
      "!**/.env.local",
      "!**/node_modules/.cache",
      "!**/tests/**",
      "!**/_archive/**",
      "!**/node_modules/playwright/**",
      "!**/node_modules/playwright-core/**",
      "!**/node_modules/@playwright/**",
      "!**/node_modules/electron/dist/**",
      "!**/node_modules/electron-builder/**",
      "!**/node_modules/electron-rebuild/**",
      "!**/*.map",
      "!**/*.ts",
      "!**/node_modules/**/test/**",
      "!**/node_modules/**/tests/**",
      "!**/node_modules/**/spec/**",
      "!**/node_modules/**/docs/**",
      "!**/node_modules/**/example/**",
      "!**/node_modules/**/examples/**"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "EHTSM",
      "repo": "jarvis-os",
      "releaseType": "release"
    },
    "protocols": [
      {
        "name": "Ooplix",
        "schemes": [
          "ooplix"
        ]
      }
    ]
  },
  "dependencies": {
    "axios": "^1.16.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "groq-sdk": "^1.1.2",
    "https-proxy-agent": "^9.0.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.1.0",
    "node-telegram-bot-api": "^0.63.0",
    "openai": "^6.34.0",
    "playwright": "^1.60.0",
    "razorpay": "^2.9.6",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.4.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EHTSM/jarvis-os.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "jarvis",
    "ai",
    "automation"
  ],
  "author": "EHTSM",
  "license": "ISC"
}
