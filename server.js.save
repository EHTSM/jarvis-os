// POST - Schedule an auto task (JARVIS does it automatically)
app.post("/auto-agent/schedule", async (req, res) => {
    try {
        const { command, delay, interval } = req.body;

        if (!command) {
            return res.status(400).json({ error: "Command is required" });
        }

        console.log(`🤖 Auto-Agent: Scheduling "${command}"`);

        // Create auto-agent task
        const autoTask = {
            id: `auto_${Date.now()}`,
            command: command,
            status: 'scheduled',
            createdAt: new Date(),
            delay: delay || 5000,  // Default 5 seconds
            interval: interval,    // Optional recurring
            isAuto: true
        };

        console.log(`✅ Auto-agent task created: ${autoTask.id}`);

        // If interval, make it recurring
        if (interval) {
            console.log(`🔄 Auto-task will repeat every ${interval}ms`);
        }

        res.json({
            success: true,
            task: autoTask,
            message: `Auto-agent task scheduled: ${command}`
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to schedule auto-task", details: error.message });
    }
});

