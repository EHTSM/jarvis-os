// 🔮 PREDICTIVE SUGGESTIONS - Next command prediction
app.post("/predict/next-commands", (req, res) => {
    try {
        const { currentCommand } = req.body;

        if (!currentCommand) {
            return res.status(400).json({ error: "Current command is required" });
        }

        const history = commandHistory.commands;
        const predictions = [];

        // Find sequences: if currentCommand was followed by X, suggest X
        for (let i = 0; i < history.length - 1; i++) {
            if (history[i].parsed?.type === currentCommand ||
                history[i].command?.includes(currentCommand)) {
                const nextType = history[i + 1].parsed?.type;
                if (nextType) {
                    const existing = predictions.find(p => p.type === nextType);
                    if (existing) {
                        existing.frequency += 1;
                    } else {
                        predictions.push({ type: nextType, frequency: 1 });
                    }
                }
            }
        }

        const sorted = predictions
            .sort((a, b) => b.frequency - a.frequency)
            .slice(0, 3)
            .map((p, idx) => ({
                rank: idx + 1,
                suggestedType: p.type,
                likelihood: Math.min(100, p.frequency * 30),
                example: `Try: ${p.type} command next`
            }));

        res.json({
            success: true,
            for: currentCommand,
            predictions: sorted,
            confidence: sorted.length > 0 ? "high" : "low"
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to predict", details: error.message });
    }
});

// 🔗 COMMAND WORKFLOWS - Chain multiple commands
app.post("/workflow/create", (req, res) => {
    try {
        const { name, commands, description } = req.body;

        if (!name || !commands || !Array.isArray(commands)) {
            return res.status(400).json({ error: "Name and commands array required" });
        }

        const workflowId = `workflow_${Date.now()}`;
        workflows[workflowId] = {
            id: workflowId,
            name: name,
            description: description || "",
            commands: commands,
            createdAt: new Date(),
            executionCount: 0
        };

        res.json({
            success: true,
            workflow: workflows[workflowId],
            message: `Workflow '${name}' created with ${commands.length} commands`
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to create workflow", details: error.message });
    }
});

app.post("/workflow/execute", (req, res) => {
    try {
        const { workflowId } = req.body;

        const workflow = workflows[workflowId];
        if (!workflow) {
            return res.status(404).json({ error: "Workflow not found" });
        }

        const results = [];

        // Execute all commands in sequence
        workflow.commands.forEach((cmd, idx) => {
            const parsed = parseCommand(cmd);
            const result = executeCommand(parsed);
            commandHistory.addCommand(cmd, parsed, result);
            results.push({
                step: idx + 1,
                command: cmd,
                success: result.success
            });
        });

        workflow.executionCount += 1;
        workflow.lastExecutedAt = new Date();

        res.json({
            success: true,
            workflow: workflow.name,
            executedCommands: results.length,
            results: results,
            message: `Workflow executed: ${results.length} commands processed`
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to execute workflow", details: error.message });
    }
});

app.get("/workflow/list", (req, res) => {
    try {
        const list = Object.values(workflows).map(w => ({
            id: w.id,
            name: w.name,
            stepCount: w.commands.length,
            executionCount: w.executionCount,
            lastExecutedAt: w.lastExecutedAt || "Never"
        }));

        res.json({
            success: true,
            workflows: list,
            totalWorkflows: list.length
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to list workflows", details: error.message });
    }
});

// � N8N INTEGRATION - Export workflows for n8n
app.get("/workflow/export-n8n", (req, res) => {
    try {
        const n8nWorkflows = Object.values(workflows).map(w => {
            // Convert JARVIS workflow to n8n format
            return {
                name: w.name,
                description: w.description,
                nodes: [
                    {
                        parameters: {},
                        name: "Start",
                        type: "n8n-nodes-base.start",
                        typeVersion: 1,
                        position: [250, 300]
                    },
                    ...(w.commands.map((cmd, idx) => ({
                        parameters: {
                            method: "POST",
                            url: "http://localhost:3000/jarvis",
                            bodyParameters: [
                                {
                                    name: "command",
                                    value: cmd
                                }
                            ]
                        },
                        name: `Execute: ${cmd.substring(0, 30)}`,
                        type: "n8n-nodes-base.httpRequest",
                        typeVersion: 3,
                        position: [450 + (idx * 200), 300]
                    }))),
                    {
                        parameters: {},
                        name: "End",
                        type: "n8n-nodes-base.noOp",
                        typeVersion: 1,
                        position: [450 + (w.commands.length * 200), 300]
                    }
                ],
                active: true,
                settings: {
                    timezone: "America/New_York"
                },
                tags: ["jarvis", "automated"]
            };
        });

        res.json({
            success: true,
            n8nWorkflows: n8nWorkflows,
            format: "n8n-compatible",
            totalWorkflows: n8nWorkflows.length,
            description: "Export JARVIS workflows in n8n format"
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to export n8n workflows", details: error.message });
    }
});

// 🔄 N8N WEBHOOK - Trigger workflow from n8n
app.post("/workflow/n8n-trigger", (req, res) => {
    try {
        const { workflowId } = req.body;

        const workflow = workflows[workflowId];
        if (!workflow) {
            return res.status(404).json({ error: "Workflow not found" });
        }

        // Execute the workflow
        const results = [];
        workflow.commands.forEach((cmd, idx) => {
            const parsed = parseCommand(cmd);
            const result = executeCommand(parsed);
            results.push({
                step: idx + 1,
                command: cmd,
                status: result.success ? "success" : "failed",
                result: result
            });
        });

        workflow.executionCount += 1;
        workflow.lastExecutedAt = new Date();

        res.json({
            success: true,
            workflow: workflow.name,
            executedSteps: results.length,
            results: results,
            message: `N8N triggered workflow '${workflow.name}' completed`
        });
    } catch (error) {
        res.status(500).json({ error: "N8N workflow trigger failed", details: error.message });
    }
});

// �📊 STATISTICS DASHBOARD

// 🔗 N8N SYNC - Direct sync to N8N container
app.post("/workflow/sync-to-n8n", (req, res) => {
    try {
        const n8nWorkflows = Object.values(workflows).map(w => {
            // Convert JARVIS workflow to n8n format with proper connections
            const nodes = [
                {
                    parameters: {},
                    name: "Start",
                    type: "n8n-nodes-base.start",
                    typeVersion: 1,
                    position: [250, 300]
                }
            ];

            let xPos = 450;
            w.commands.forEach((cmd, idx) => {
                nodes.push({
                    parameters: {
                        method: "POST",
                        url: "http://localhost:3000/jarvis",
                        bodyParameters: [{ name: "command", value: cmd }]
                    },
                    name: `Execute: ${cmd}`,
                    type: "n8n-nodes-base.httpRequest",
                    typeVersion: 3,
                    position: [xPos, 300]
                });
                xPos += 200;
            });

            nodes.push({
                parameters: {},
                name: "End",
                type: "n8n-nodes-base.noOp",
                typeVersion: 1,
                position: [xPos, 300]
            });

            // Create connections
            const connections = {
                "Start": {
                    main: [[{ node: `Execute: ${w.commands[0]}`, type: "main", index: 0 }]]
                }
            };

            w.commands.forEach((cmd, idx) => {
                if (idx < w.commands.length - 1) {
                    connections[`Execute: ${cmd}`] = {
                        main: [[{ node: `Execute: ${w.commands[idx + 1]}`, type: "main", index: 0 }]]
                    };
                } else {
                    connections[`Execute: ${cmd}`] = {
                        main: [[{ node: "End", type: "main", index: 0 }]]
                    };
                }
            });

            return {
                name: w.name,
                description: w.description || "JARVIS workflow",
                active: true,
                nodes: nodes,
                connections: connections,
                tags: ["jarvis", "automated"]
            };
        });

        // Try to write to N8N directory
        const fs = require('fs');
        const path = require('path');
        const homeDir = process.env.HOME || '/root';
        const n8nDir = path.join(homeDir, '.n8n');
        const workflowsFile = path.join(n8nDir, 'workflows.json');

        if (!fs.existsSync(n8nDir)) {
            fs.mkdirSync(n8nDir, { recursive: true });
        }

        fs.writeFileSync(workflowsFile, JSON.stringify({ workflows: n8nWorkflows }, null, 2));

        res.json({
            success: true,
            message: `Synced ${n8nWorkflows.length} workflows to N8N`,
            workflowsFile: workflowsFile,
            workflows: n8nWorkflows.map(w => ({ name: w.name, nodeCount: w.nodes.length })),
            instructions: "Workflows written to N8N directory. Restart N8N container to load them."
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to sync to N8N", details: error.message });
    }
});
app.get("/stats/usage", (req, res) => {
    try {
        const history = commandHistory.commands;
        const now = new Date();
        const hourAgo = new Date(now - 3600000);
        const dayAgo = new Date(now - 86400000);

        const lastHour = history.filter(c => new Date(c.timestamp) > hourAgo).length;
        const lastDay = history.filter(c => new Date(c.timestamp) > dayAgo).length;
        const freq = commandHistory.getFrequency();

        res.json({
            success: true,
            commandsLastHour: lastHour,
            commandsLastDay: lastDay,
            totalCommands: history.length,
            avgPerDay: lastDay > 0 ? (lastDay / 1).toFixed(2) : 0,
            topCommands: Object.entries(freq)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 5)
                .map(([type, count]) => ({ type, count }))
        });
