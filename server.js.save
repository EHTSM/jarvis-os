// 🤖 POST - Create new agent
app.post("/agents/create", async (req, res) => {
    try {
        const { name, type, spec } = req.body;

        if (!name || !type) {
            return res.status(400).json({
                error: "Agent name and type are required",
                available_types: ["api", "processor", "scheduler", "analyzer"]
            });
        }

        const result = agentFactory.createAgent(name, type, spec || {});

        if (!result.success) {
            return res.status(400).json(result);
        }

        res.json({
            success: true,
            ...result
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to create agent", details: error.message });
    }
});

// ========================================
// 🚀 500 SPECIALIZED AGENTS SYSTEM (IRON MAN LEVEL)
// Like Iron Man's JARVIS - 500 specialized AI agents
// ========================================

let masterAgentManager = null;

// Initialize 500-agent system
async function initializeMasterAgentManager() {
    try {
        const MasterAgentManager = require('./agents/MasterAgentManager');
        masterAgentManager = new MasterAgentManager();
        await masterAgentManager.initialize();
        console.log('\n✅ Master Agent Manager online - 500 agents active!\n');
        return true;
    } catch (error) {
        console.error('⚠️  Master Agent Manager initialization failed:', error.message);
        console.error('Make sure /Users/ehtsm/agents/ directory exists with agent files');
        return false;
    }
}

// POST - Execute task with intelligent agent routing
app.post("/agents/500/execute", async (req, res) => {
    try {
        if (!masterAgentManager) {
            return res.status(503).json({
                error: "500-Agent system not initialized",
                message: "Run /agents/500/initialize first"
            });
        }

        const { task, domain, collaborative } = req.body;

        if (!task) {
            return res.status(400).json({ error: "Task required" });
        }

        let result;
        if (collaborative) {
            // Use multiple agents for complex tasks
            result = await masterAgentManager.executeTaskWithTeam(
                { name: task.name, type: task.type, domain: task.domain || domain },
                collaborative.numberOfAgents || 3
            );
        } else {
            // Route to single best agent
            result = await masterAgentManager.routeTask({
                name: task.name,
                type: task.type,
                domain: task.domain || domain
            });
        }

        res.json({
            success: true,
            result,
            timestamp: new Date().toISOString()
        });
    } catch (error) {
        res.status(500).json({
            error: "Task execution failed",
            details: error.message
        });
    }
});

// GET - Get all 500 agents status
app.get("/agents/500/status", (req, res) => {
    try {
        if (!masterAgentManager) {
            return res.json({
                status: 'NOT_INITIALIZED',
                message: 'Run /agents/500/initialize to activate 500-agent system'
            });
        }

        const stats = masterAgentManager.getSystemStatistics();
        const agents = masterAgentManager.listAllAgents();

        res.json({
            success: true,
            system_status: 'ACTIVE',
            statistics: stats,
            agent_inventory: agents
        });
    } catch (error) {
        res.status(500).json({
            error: "Failed to get status",
            details: error.message
        });
    }
});

