const express = require("express");
const { exec } = require("child_process");
require("dotenv").config();

const { orchestrator, getMemoryState, clearMemoryState, contextEngine, learningSystem, voiceAgent, desktopAgent, agentFactory, evolutionEngine } = require("./orchestrator");
const { getScheduledTasks, cancelTask, getSchedulerStatus, clearAllTasks, getTask } = require("./scheduler");
const { parseCommand, executeCommand } = require("./commandParser");

const app = express();
app.use(express.json());

// 🌐 CORS Configuration - Allow frontend to make requests
app.use((req, res, next) => {
    res.header('Access-Control-Allow-Origin', '*');
    res.header('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');
    res.header('Access-Control-Allow-Headers', 'Content-Type, Authorization');

    // Handle preflight requests
    if (req.method === 'OPTIONS') {
        return res.sendStatus(200);
    }
    next();
});

// 🧠 COMMAND HISTORY & MEMORY TRACKING
const commandHistory = {
    commands: [],
    suggestions: [],
    addCommand: function (cmd, parsed, result) {
        this.commands.push({
            command: cmd,
            type: parsed.type,
            timestamp: new Date(),
            success: result.success
        });
        // Keep last 50 commands
        if (this.commands.length > 50) this.commands.shift();
    },
    getFrequency: function () {
        const freq = {};
        this.commands.forEach(cmd => {
            freq[cmd.type] = (freq[cmd.type] || 0) + 1;
        });
        return freq;
    },
    getSuggestions: function () {
        const freq = this.getFrequency();
        return Object.entries(freq)
            .sort((a, b) => b[1] - a[1])
            .slice(0, 5)
            .map(([type, count]) => ({
                type,
                frequency: count,
                suggestion: `You often use ${type} commands (${count} times)`
            }));
    }
};

// ✅ HEALTH CHECK ROUTE
app.get("/", (req, res) => {
    res.send("






Jarvis Server is Running 🚀 (Multi-Agent Orchestrator + Scheduler + Voice + Desktop Control)");
});

// ✅ JARVIS MULTI-AGENT ORCHESTRATOR ROUTE
// All requests go through: planner → executor → memory
app.post("/jarvis", async (req, res) => {
    try {
        const userInput = req.body.command;

        // ❗ Check for empty input
        if (!userInput) {
            return res.status(400).json({
                error: "Command is required"
            });
        }

        console.log("📥 User input:", userInput);

        // ✅ ROUTE THROUGH ORCHESTRATOR: planner → executor → memory
        const result = await orchestrator(userInput);

        console.log("📤 Orchestrator result:", {
            tasks_parsed: result.tasks.length,
            results_generated: result.results.length,
            processed_by: result.memory_status?.processedBy || "Unknown"
        });

        res.json({
            success: true,
            ...result
        });

    } catch (error) {
        console.error("❌ Orchestrator error:", error);

        res.status(500).json({
            error: "Processing failed",
            details: error.message
        });
    }
});

// ✅ GET MEMORY ROUTE
// Access orchestrator's internal memory state
app.get("/memory", (req, res) => {
    try {
        const memoryState = getMemoryState();

        res.json({
            success: true,
            memory_state: memoryState,
            short_term_count: memoryState?.shortTerm?.length || 0,
            long_term_count: memoryState?.longTerm?.length || 0
        });
    } catch (error) {
        res.status(500).json({
            error: "Failed to retrieve memory",
            details: error.message
        });
    }
});

// ✅ DELETE MEMORY ROUTE
// Clear orchestrator's internal memory
app.delete("/memory", (req, res) => {
    try {
        const previousState = getMemoryState();
        const previousCount = (previousState?.shortTerm?.length || 0) + (previousState?.longTerm?.length || 0);

        clearMemoryState();

        const newState = getMemoryState();
        const newCount = (newState?.shortTerm?.length || 0) + (newState?.longTerm?.length || 0);

        res.json({
            success: true,
            message: "Memory cleared",
            previous_memory_count: previousCount,
            current_memory_count: newCount
        });
    } catch (error) {
        res.status(500).json({
            error: "Failed to clear memory",
            details: error.message
        });
    }
});

