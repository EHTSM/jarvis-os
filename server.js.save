// GET - Get specific agent details
app.get("/agents/500/:agentName", (req, res) => {
    try {
        if (!masterAgentManager) {
            return res.status(503).json({ error: "500-Agent system not initialized" });
        }

        const agent = masterAgentManager.getAgent(req.params.agentName);

        if (!agent) {
            return res.status(404).json({ error: "Agent not found" });
        }

        res.json({
            success: true,
            agent: {
                name: agent.name,
                domain: agent.domain,
                status: agent.getStatus(),
                capabilities: agent.getCapabilities()
            }
        });
    } catch (error) {
        res.status(500).json({
            error: "Failed to get agent details",
            details: error.message
        });
    }
});

// POST - Execute task with agents from specific domain
app.post("/agents/500/domain/:domain", async (req, res) => {
    try {
        if (!masterAgentManager) {
            return res.status(503).json({ error: "500-Agent system not initialized" });
        }

        const { task } = req.body;
        const domain = req.params.domain.toUpperCase();

        if (!task) {
            return res.status(400).json({ error: "Task required" });
        }

        const result = await masterAgentManager.routeTask(
            { name: task.name, type: task.type, domain: task.domain },
            domain
        );

        res.json({
            success: true,
            domain,
            result,
            timestamp: new Date().toISOString()
        });
    } catch (error) {
        res.status(500).json({
            error: "Task execution failed",
            details: error.message
        });
    }
});

// POST - Start continuous learning mode
app.post("/agents/500/start-learning", async (req, res) => {
    try {
        if (!masterAgentManager) {
            return res.status(503).json({ error: "500-Agent system not initialized" });
        }

        const interval = await masterAgentManager.startContinuousLearning();

        res.json({
            success: true,
            message: "Continuous learning mode activated",
            interval: "60 seconds",
            note: "Agents will self-improve every minute"
        });
    } catch (error) {
        res.status(500).json({
            error: "Failed to start learning",
            details: error.message
        });
    }
});

// GET - Initialize 500-agent system on demand
app.get("/agents/500/initialize", async (req, res) => {
    try {
        if (masterAgentManager && masterAgentManager.initialized) {
            return res.json({
                success: true,
                status: 'ALREADY_INITIALIZED',
                message: '500-Agent system already active'
            });
        }

        const initialized = await initializeMasterAgentManager();

        if (initialized) {
            res.json({
                success: true,
                message: '✅ 500-Agent system initialized!',
                agents: masterAgentManager.agents.size,
                domains: masterAgentManager.agentsByDomain.size,
                next_steps: [
                    'GET /agents/500/status - View system status',
                    'POST /agents/500/execute - Execute a task',
                    'GET /agents/500/by-domain - List agents by domain',
                    'POST /agents/500/start-learning - Enable continuous improvement'
                ]
            });
        } else {
            res.status(500).json({
                error: 'Initialization failed',
                message: 'Please ensure agent files are in /Users/ehtsm/agents/'
            });
        }
    } catch (error) {
        res.status(500).json({
            error: "Initialization error",
            details: error.message
        });
    }
});

