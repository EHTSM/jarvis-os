app.post("/agents/create", (req, res) => {
    try {
        const { name, role, skills, priority, description } = req.body;

        if (!name || !role) {
            return res.status(400).json({ error: "Name and role are required" });
        }

        agentCounter++;
        const agentId = `agent_${agentCounter}`;

        const newAgent = {
            id: agentId,
            name: name,
            role: role,
            skills: skills || [],
            priority: priority || 50,
            description: description || `Agent specialized in ${role}`,
            createdAt: new Date(),
            isActive: true,
            executionCount: 0,
            successCount: 0,
            rating: 0
        };

        dynamicAgents[agentId] = newAgent;

        console.log(`🤖 New Agent Created: ${name} (${agentId})`);

        res.json({
            success: true,
            agent: newAgent,
            message: `Agent '${name}' created successfully with ID: ${agentId}`
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to create agent", details: error.message });
    }
});

// GET - List all agents
app.get("/agents/list", (req, res) => {
    try {
        const agents = Object.values(dynamicAgents)
            .sort((a, b) => b.priority - a.priority);

        const coreAgents = [
            { name: "Master Controller", priority: 100, status: "Active" },
            { name: "Command Interpreter", priority: 95, status: "Active" },
            { name: "Context Manager", priority: 90, status: "Active" },
            { name: "Memory Agent", priority: 85, status: "Active" },
            { name: "Decision Engine", priority: 80, status: "Active" },
            { name: "Task Splitter", priority: 75, status: "Active" },
            { name: "Priority Manager", priority: 70, status: "Active" },
            { name: "Workflow Generator", priority: 65, status: "Active" },
            { name: "Workflow Executor", priority: 60, status: "Active" },
            { name: "Response Generator", priority: 55, status: "Active" }
        ];

        res.json({
            success: true,
            coreAgents: coreAgents,
            dynamicAgents: agents,
            totalAgents: coreAgents.length + agents.length,
            totalDynamic: agents.length
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to list agents", details: error.message });
    }
});

// POST - Execute specific agent
app.post("/agents/:agentId/execute", (req, res) => {
    try {
        const { agentId } = req.params;
        const { task } = req.body;

        const agent = dynamicAgents[agentId];
        if (!agent) {
            return res.status(404).json({ error: "Agent not found" });
        }

        agent.executionCount++;

        // Simulate task execution
        const result = {
            agentId: agentId,
            agentName: agent.name,
            task: task,
            status: 'completed',
            executedAt: new Date(),
            result: `Task executed by ${agent.name}: ${task}`
        };

        agent.successCount++;
        agent.rating = Math.min(100, (agent.successCount / agent.executionCount) * 100);

        res.json({
            success: true,
            agent: agent,
            executionResult: result
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to execute agent", details: error.message });
    }
});

// DELETE - Remove an agent
app.delete("/agents/:agentId", (req, res) => {
    try {
        const { agentId } = req.params;

        if (!dynamicAgents[agentId]) {
            return res.status(404).json({ error: "Agent not found" });
        }

        const agentName = dynamicAgents[agentId].name;
        delete dynamicAgents[agentId];

        res.json({
            success: true,
            message: `Agent '${agentName}' deleted successfully`
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to delete agent", details: error.message });
    }
});

// ========================================
// 📚 KNOWLEDGE BASE AGENT - Persistent learning
// ========================================

const knowledgeBase = {
    facts: [],
    skills: [],
    patterns: [],

    addFact: function (fact, category, source) {
        this.facts.push({
            id: `fact_${Date.now()}`,
            content: fact,
            category: category || "general",
            source: source || "user",
            addedAt: new Date(),
            accessCount: 0
        });
        return this.facts[this.facts.length - 1];
    },

    addSkill: function (skillName, description, examples) {
        this.skills.push({
            id: `skill_${Date.now()}`,
            name: skillName,
            description: description,
            examples: examples || [],
            masteryLevel: 'beginner',
            addedAt: new Date()
        });
        return this.skills[this.skills.length - 1];
    },

    searchFacts: function (query) {
        return this.facts.filter(f =>
            f.content.toLowerCase().includes(query.toLowerCase()) ||
            f.category.toLowerCase().includes(query.toLowerCase())
        );
    }
};

// POST - Add knowledge/fact
app.post("/knowledge/add-fact", (req, res) => {
    try {
        const { fact, category, source } = req.body;

        if (!fact) {
            return res.status(400).json({ error: "Fact content is required" });
        }

        const newFact = knowledgeBase.addFact(fact, category, source);

        res.json({
            success: true,
            fact: newFact,
            message: `Fact added to knowledge base`
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to add fact", details: error.message });
    }
});

// POST - Learn new skill
app.post("/knowledge/learn-skill", (req, res) => {
    try {
        const { skillName, description, examples } = req.body;

        if (!skillName) {
            return res.status(400).json({ error: "Skill name is required" });
        }

        const newSkill = knowledgeBase.addSkill(skillName, description, examples);

        res.json({
            success: true,
            skill: newSkill,
            message: `Skill '${skillName}' learned successfully`
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to learn skill", details: error.message });
    }
});

// GET - Search knowledge base
app.get("/knowledge/search", (req, res) => {
    try {
        const query = req.query.q || '';
        const facts = knowledgeBase.searchFacts(query);

        res.json({
            success: true,
            query: query,
            factsFound: facts.length,
            facts: facts,
            totalFacts: knowledgeBase.facts.length,
            totalSkills: knowledgeBase.skills.length
        });
    } catch (error) {
        res.status(500).json({ error: "Search failed", details: error.message });
    }
});

// ========================================
// 🔧 ERROR RECOVERY AGENT - Smart failure handling
// ========================================

const errorRecoverySystem = {
    strategies: {
        'command_not_found': [
            'Try similar command',
            'Check command syntax',
            'Search knowledge base',
            'Create new agent for this command'
        ],
        'execution_failed': [
            'Retry with different parameters',
            'Try alternate approach',
            'Break into subtasks',
            'Ask for manual confirmation'
        ],
        'timeout': [
            'Increase timeout limit',
            'Break into smaller tasks',
            'Retry operation',
            'Skip and continue'
        ]
    },

    recover: function (errorType, task) {
        const strategies = this.strategies[errorType] || ['Retry', 'Skip', 'Report error'];
        return {
            errorType: errorType,
            task: task,
            recoveryStrategies: strategies,
            recommendedStrategy: strategies[0],
            autoRetryEnabled: true,
            retryCount: 0,
            maxRetries: 3
        };
    }
};

// POST - Handle error with recovery
app.post("/error-recovery/handle", (req, res) => {
    try {
        const { errorType, task, message } = req.body;

        if (!errorType || !task) {
            return res.status(400).json({ error: "Error type and task are required" });
        }

        const recovery = errorRecoverySystem.recover(errorType, task);

        res.json({
            success: true,
            errorHandling: recovery,
            message: `Error recovery initiated for ${errorType}`
        });
    } catch (error) {
        res.status(500).json({ error: "Recovery failed", details: error.message });
    }
});

// ========================================
// 🚀 PHASE 5: TOP 50 AGENTS MANAGEMENT
// ========================================

const agentRegistry = {
    topAgents: [
        { rank: 1, name: "Master Controller", specialty: "Orchestration", rating: 10 },
        { rank: 2, name: "Command Interpreter", specialty: "NLP", rating: 9.8 },
        { rank: 3, name: "Context Manager", specialty: "State", rating: 9.7 },
        { rank: 4, name: "Voice Agent", specialty: "Speech", rating: 9.6 },
        { rank: 5, name: "Memory Agent", specialty: "Learning", rating: 9.5 }
    ],

    specializedAgents: {}
};

// POST - Promote agent to top agents list
app.post("/agents/promote", (req, res) => {
    try {
        const { agentId, agentName, specialty } = req.body;

        if (!agentName || !specialty) {
            return res.status(400).json({ error: "Agent name and specialty required" });
        }

        const newRank = agentRegistry.topAgents.length + 1;

        if (newRank <= 50) {
            agentRegistry.topAgents.push({
                rank: newRank,
                name: agentName,
                specialty: specialty,
                rating: 8.0,
                promotedAt: new Date()
            });

            res.json({
                success: true,
                message: `Agent promoted to rank ${newRank}`,
                topAgentsCount: agentRegistry.topAgents.length
            });
        } else {
            res.status(400).json({ error: "Top 50 agents list is full" });
        }
    } catch (error) {
        res.status(500).json({ error: "Promotion failed", details: error.message });
    }
});

// GET - Get top 50 agents
app.get("/agents/top-50", (req, res) => {
    try {
        const topAgents = agentRegistry.topAgents.slice(0, 50);

        res.json({
            success: true,
            totalInTop50: topAgents.length,
            topAgents: topAgents,
            categories: {
                orchestration: topAgents.filter(a => a.specialty === "Orchestration").length,
                nlp: topAgents.filter(a => a.specialty === "NLP").length,
                voice: topAgents.filter(a => a.specialty === "Speech").length,
                other: topAgents.filter(a => !["Orchestration", "NLP", "Speech"].includes(a.specialty)).length
            }
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to get top agents", details: error.message });
    }
});

// ========================================
// 🎯 AGENT DELEGATION SYSTEM - Smart task assignment
// ========================================

// POST - Delegate task to best agent
app.post("/agents/delegate", (req, res) => {
    try {
        const { task, expertiseRequired } = req.body;

        if (!task || !expertiseRequired) {
            return res.status(400).json({ error: "Task and expertise required" });
        }

        // Find best agent for this task
        const topAgents = agentRegistry.topAgents;
        let bestAgent = topAgents[0];

        // Match expertise
        for (let agent of topAgents) {
            if (agent.specialty.toLowerCase().includes(expertiseRequired[0].toLowerCase())) {
                bestAgent = agent;
                break;
            }
        }

        const delegation = {
            task: task,
            delegatedTo: bestAgent.name,
            agentRank: bestAgent.rank,
            expertise: bestAgent.specialty,
            confidence: Math.min(100, bestAgent.rating * 10),
            status: 'delegated',
            timestamp: new Date()
        };

        res.json({
            success: true,
            delegation: delegation,
            message: `Task delegated to ${bestAgent.name}`
        });
    } catch (error) {
        res.status(500).json({ error: "Delegation failed", details: error.message });
    }
});

// GET - Get agent specializations
app.get("/agents/specializations", (req, res) => {
    try {
        const specs = {};
        agentRegistry.topAgents.forEach(agent => {
            if (!specs[agent.specialty]) {
                specs[agent.specialty] = [];
            }
            specs[agent.specialty].push(agent.name);
        });

        res.json({
            success: true,
            specializations: specs,
            totalSpecialties: Object.keys(specs).length
        });
    } catch (error) {
        res.status(500).json({ error: "Failed to get specializations", details: error.message });
    }
});

