// ========================================
// 🚀 PHASE 4: SELF-IMPROVING JARVIS
// ========================================

// 🧠 SELF-IMPROVEMENT AGENT - Analyzes JARVIS's own performance
const selfImprovalSystem = {
    metrics: {
        totalCommands: 0,
        successfulCommands: 0,
        failedCommands: 0,
        averageResponseTime: 0,
        userSatisfaction: 0,
        accuracyScore: 0
    },
    improvements: [],
    weaknesses: [],
    strengths: [],

    analyze: function () {
        const history = commandHistory.commands;
        const successCount = history.filter(c => c.success).length;
        const failCount = history.length - successCount;

        this.metrics = {
            totalCommands: history.length,
            successfulCommands: successCount,
            failedCommands: failCount,
            succesRate: history.length > 0 ? ((successCount / history.length) * 100).toFixed(2) + '%' : 'N/A',
            averageResponseTime: '50ms',
            userSatisfaction: Math.min(100, successCount * 2),
            accuracyScore: history.length > 0 ? ((successCount / history.length) * 100).toFixed(2) : 0
        };

        // Identify weaknesses
        const freq = commandHistory.getFrequency();
        this.weaknesses = Object.entries(freq)
            .filter(([type, count]) => count < 2)
            .map(([type, count]) => ({
                commandType: type,
                issues: count === 1 ? 'Rare command - may need improvement' : 'Unknown/unsupported',
                priority: 'Low'
            }));

        // Identify strengths
        this.strengths = Object.entries(freq)
            .filter(([type, count]) => count >= 3)
            .map(([type, count]) => ({
                commandType: type,
                strength: `Excellent at ${type} commands (${count} successful executions)`,
                confidence: Math.min(100, count * 20)
            }));

        return this.metrics;
    },

    suggest: function () {
        const suggestions = [];

        if (this.metrics.successRate < 80) {
            suggestions.push({
                priority: 'HIGH',
                suggestion: 'Improve accuracy for command parsing',
                action: 'Review parseCommand patterns',
                expectedImprovement: '+15% accuracy'
            });
        }

        if (this.weaknesses.length > 3) {
            suggestions.push({
                priority: 'MEDIUM',
                suggestion: 'Add support for more command types',
                action: 'Create new command parsers',
                expectedImprovement: '+20% coverage'
            });
        }

        this.improvements = suggestions;
        return suggestions;
    }
};

// GET - Self-improvement analysis
app.get("/self-improve/analyze", (req, res) => {
    try {
        const metrics = selfImprovalSystem.analyze();
        const suggestions = selfImprovalSystem.suggest();

        res.json({
            success: true,
            systemMetrics: metrics,
            weaknesses: selfImprovalSystem.weaknesses,
            strengths: selfImprovalSystem.strengths,
            suggestedImprovements: suggestions,
            message: `JARVIS analyzed ${metrics.totalCommands} commands`
        });
    } catch (error) {
        res.status(500).json({ error: "Self-improvement analysis failed", details: error.message });
    }
});

// GET - Accuracy evaluation
app.get("/self-improve/evaluation", (req, res) => {
    try {
        const metrics = selfImprovalSystem.analyze();

        res.json({
            success: true,
            accuracyScore: metrics.accuracyScore,
            successRate: metrics.succesRate,
            totalCommands: metrics.totalCommands,
            recommendation: metrics.accuracyScore >= 80 ? "System performing well" : "Focus on improvement areas",
            nextSteps: selfImprovalSystem.suggest().slice(0, 3)
        });
    } catch (error) {
        res.status(500).json({ error: "Evaluation failed", details: error.message });
    }
});

