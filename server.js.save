            return res.status(400).json({ error: "Title and time are required" });
        }

        // Simple date parsing
        const eventId = `event_${Date.now()}`;
        const eventTime = new Date(time);

        calendarEvents[eventId] = {
            id: eventId,
            title: title,
            scheduledTime: eventTime,
            description: description || "",
            createdAt: new Date(),
            executed: false
        };

        // Schedule execution on macOS Calendar
        const calendarCmd = `open -a Calendar`;
        exec(calendarCmd, (err) => {
            if (!err) console.log("📅 Event added to Calendar");
        });

        res.json({
            success: true,
            event: calendarEvents[eventId],
            message: `Event scheduled: ${title} at ${eventTime}`
        });
