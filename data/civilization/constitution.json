{
  "articles": [
    {
      "id": "cart_1782601786594_n5sg",
      "articleNumber": 1,
      "title": "Right to Participate",
      "content": "Every registered member has the right to participate in civilization activities, missions, and governance.",
      "category": "rights",
      "status": "active",
      "adoptedAt": "2026-06-27T23:09:46.594Z"
    },
    {
      "id": "cart_1782601786594_wprz",
      "articleNumber": 2,
      "title": "Obligation to Cooperate",
      "content": "Members must cooperate in good faith for civilization-wide missions and knowledge sharing.",
      "category": "obligations",
      "status": "active",
      "adoptedAt": "2026-06-27T23:09:46.594Z"
    },
    {
      "id": "cart_1782601786595_kuhq",
      "articleNumber": 3,
      "title": "Resource Reciprocity",
      "content": "Members who contribute resources to the civilization pool have priority access to pool claims.",
      "category": "economy",
      "status": "active",
      "adoptedAt": "2026-06-27T23:09:46.595Z"
    },
    {
      "id": "cart_1782601786595_je7h",
      "articleNumber": 4,
      "title": "Dispute Resolution",
      "content": "All disputes must first go through negotiation, then arbitration, before escalating to Council.",
      "category": "governance",
      "status": "active",
      "adoptedAt": "2026-06-27T23:09:46.595Z"
    },
    {
      "id": "cart_1782601786595_3iqg",
      "articleNumber": 5,
      "title": "Innovation Adoption",
      "content": "Innovations with 3+ adoptions are considered civilization standards and are recommended for all members.",
      "category": "innovation",
      "status": "active",
      "adoptedAt": "2026-06-27T23:09:46.595Z"
    },
    {
      "id": "cart_1782601786595_jjly",
      "articleNumber": 6,
      "title": "Reputation Integrity",
      "content": "Reputation scores are immutable historical records. Manipulation of reputation is grounds for expulsion.",
      "category": "governance",
      "status": "active",
      "adoptedAt": "2026-06-27T23:09:46.595Z"
    },
    {
