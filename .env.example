# ─── Server ────────────────────────────────────────────────────────
PORT=5050
NODE_ENV=production

# Public-facing base URL — required for Razorpay webhook callbacks.
# Must be https:// for Razorpay production webhooks to reach you.
BASE_URL=https://your-domain.com

# ─── AI Provider ───────────────────────────────────────────────────
# Primary: Groq (fast, free tier — https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_PROVIDER=groq

# Optional: OpenAI (Whisper STT only)
OPENAI_API_KEY=sk-your_openai_key_here

# ─── WhatsApp (Meta Business API) ─────────────────────────────────
# From Meta Developer Console → Your App → WhatsApp → API Setup
WA_TOKEN=your_whatsapp_access_token
WA_PHONE_ID=your_phone_number_id
WA_API_VERSION=v19.0
# Set this to any secret string — must match what you enter in Meta webhook config
WA_VERIFY_TOKEN=change_this_to_a_secret_string
WA_BUSINESS_ACCOUNT_ID=your_business_account_id

# ─── Telegram ──────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
# Fallback payment link shown in Telegram if Razorpay link creation fails
PAYMENT_FALLBACK_LINK=https://rzp.io/l/your-link-here

# ─── Razorpay ──────────────────────────────────────────────────────
RAZORPAY_KEY=rzp_live_your_key_here
RAZORPAY_SECRET=your_razorpay_secret
# REQUIRED in production — webhook rejected without this
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Business ──────────────────────────────────────────────────────
# Product price in INR — used for revenue calculations in CRM
PRODUCT_PRICE=999

# ─── Firebase (optional — enables mobile auth) ─────────────────────
# Paste the contents of your Firebase service account JSON as a single-line string
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── Frontend ──────────────────────────────────────────────────────
# For development: http://localhost:5050
# For production: https://your-domain.com
REACT_APP_API_URL=https://your-domain.com

# ─── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Optional integrations ─────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URL=
GOOGLE_CLIENT_ID=
GOOGLE_API=
