# ════════════════════════════════════════════════════════════════════════
#  JARVIS OS — Production environment template
#  Copy to .env and fill in EVERY value before running start-production.sh
#
#  Lines marked [REQUIRED] crash or disable a core feature if blank.
#  Lines marked [OPTIONAL] only disable a non-critical feature if blank.
# ════════════════════════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────────────
PORT=5050
# Comma-separated list of allowed CORS origins (no trailing slash).
# Required for cookies to work from a browser on a different origin.
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com
NODE_ENV=production

# [REQUIRED] Public HTTPS domain — used for Razorpay webhook callbacks.
# Without this, payments are never confirmed (Razorpay can't call localhost).
BASE_URL=https://your-domain.com

# ─── AI Provider ───────────────────────────────────────────────────────
# [REQUIRED] Groq — fast, free tier: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_PROVIDER=groq

# [OPTIONAL] OpenAI — only used for Whisper STT
OPENAI_API_KEY=sk-your_openai_key_here

# ─── WhatsApp (Meta Business API) ──────────────────────────────────────
# [REQUIRED for automation] Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_access_token
PHONE_NUMBER_ID=your_phone_number_id
WA_API_VERSION=v19.0
# Any secret string — must match what you enter in Meta webhook configuration
WA_VERIFY_TOKEN=change_this_to_a_random_secret
WA_BUSINESS_ACCOUNT_ID=your_business_account_id

# ─── Telegram ──────────────────────────────────────────────────────────
# [REQUIRED] BotFather → /newbot → copy the token
TELEGRAM_TOKEN=your_telegram_bot_token
# Fallback Razorpay link shown in Telegram if dynamic link creation fails
PAYMENT_FALLBACK_LINK=https://rzp.io/l/your-static-link

# ─── Razorpay ──────────────────────────────────────────────────────────
# [REQUIRED for payments] Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# [REQUIRED in production] Dashboard → Settings → Webhooks → your webhook → Secret
# Without this, all payment webhooks are REJECTED and payments never confirmed.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Business ──────────────────────────────────────────────────────────
# Product price in INR — used for payment link creation and revenue reports
PRODUCT_PRICE=999

# ─── Firebase (optional — enables mobile app auth) ─────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
# Paste the full service-account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── Frontend ──────────────────────────────────────────────────────────
# Single-server (nginx proxies API routes): leave BLANK — relative paths are used.
#   REACT_APP_API_URL=
# Split-server (api.ooplix.com separate backend): set to your API domain.
#   REACT_APP_API_URL=https://api.your-domain.com
REACT_APP_API_URL=

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Operator Auth ─────────────────────────────────────────────────────
# [REQUIRED in production] Generate with: node scripts/generate-password-hash.cjs <yourpassword>
OPERATOR_PASSWORD_HASH=
# [REQUIRED in production] Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── Optional integrations ─────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URL=
GOOGLE_CLIENT_ID=
GOOGLE_API=

# ════════════════════════════════════════════════════════════════════════
# PRODUCTION MISSION 3 — Real Integration Env Vars
# Set these values in the Ooplix UI → Settings → Integrations, then
# restart the server. Never commit real keys to git.
# ════════════════════════════════════════════════════════════════════════

# ─── Phase A: AI Providers (additions) ────────────────────────────────
DEEPSEEK_API_KEY=                  # platform.deepseek.com → API Keys
DEEPSEEK_MODEL=deepseek-chat
TOGETHER_API_KEY=                  # api.together.ai → Settings → API Keys
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf
FIREWORKS_API_KEY=                 # fireworks.ai → Account → API Keys
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3-70b-instruct
COHERE_API_KEY=                    # dashboard.cohere.com → API Keys
COHERE_MODEL=command-r-plus
NVIDIA_API_KEY=                    # build.nvidia.com → API Catalog → Generate key
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
LM_STUDIO_URL=http://localhost:1234    # LM Studio local server URL
LM_STUDIO_MODEL=local-model

# ─── Phase B: Git Providers ────────────────────────────────────────────
GITHUB_TOKEN=                      # github.com/settings/tokens — PAT with repo scope
GITHUB_CLIENT_ID=                  # OAuth App client ID
GITHUB_CLIENT_SECRET=              # OAuth App client secret
GITLAB_TOKEN=                      # gitlab.com → Preferences → Access Tokens
GITLAB_HOST=https://gitlab.com     # Self-hosted: https://your-gitlab.com
BITBUCKET_USER=                    # Bitbucket username
BITBUCKET_APP_PASSWORD=            # Bitbucket → Security → App Passwords

# ─── Phase C: Infrastructure (additions) ──────────────────────────────
HOSTINGER_API_KEY=                 # hPanel → Integrations → API
CLOUDFLARE_API_TOKEN=              # dash.cloudflare.com → My Profile → API Tokens
CLOUDFLARE_ACCOUNT_ID=             # Right-side bar on any Cloudflare page
SUPABASE_URL=                      # supabase.com → Project Settings → API → Project URL
SUPABASE_ANON_KEY=                 # supabase.com → Project Settings → API → anon key
SUPABASE_SERVICE_KEY=              # supabase.com → Project Settings → API → service_role key
R2_ACCESS_KEY_ID=                  # Cloudflare R2 → Manage R2 API Tokens
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ACCOUNT_ID=

# ─── Phase D: Payments (additions) ────────────────────────────────────
STRIPE_SECRET_KEY=                 # dashboard.stripe.com → Developers → API Keys
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=             # dashboard.stripe.com → Webhooks → Signing Secret
PADDLE_API_KEY=                    # vendors.paddle.com → Developer Tools → Authentication
PADDLE_VENDOR_ID=
PADDLE_WEBHOOK_SECRET=
LEMONSQUEEZY_API_KEY=              # app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ─── Phase E: Email (additions) ────────────────────────────────────────
MAILGUN_API_KEY=                   # app.mailgun.com → API Security → API Keys
MAILGUN_DOMAIN=                    # Verified domain in Mailgun
BREVO_API_KEY=                     # app.brevo.com → SMTP & API → API Keys
AWS_SES_REGION=us-east-1           # SES region (separate from S3 region if needed)
SES_FROM_EMAIL=                    # Verified SES sender identity

# ─── Phase F: Messaging (additions) ────────────────────────────────────
TWILIO_ACCOUNT_SID=                # console.twilio.com → Account Info
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=               # E.164 format: +1234567890
DISCORD_BOT_TOKEN=                 # discord.com/developers → Bot → Token
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=                  # Right-click server → Copy Server ID
DISCORD_WEBHOOK_URL=               # Channel Settings → Integrations → Webhooks
SLACK_BOT_TOKEN=                   # api.slack.com → OAuth & Permissions → Bot Token
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ─── Phase G: Auth (additions) ─────────────────────────────────────────
MICROSOFT_CLIENT_ID=               # portal.azure.com → App Registrations
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common         # Or your tenant ID
MICROSOFT_REDIRECT_URI=
APPLE_TEAM_ID=                     # developer.apple.com → Account
APPLE_CLIENT_ID=                   # Service ID (com.yourapp.signin)
APPLE_KEY_ID=                      # developer.apple.com → Keys
APPLE_PRIVATE_KEY=                 # Contents of downloaded .p8 file (single line)

# ─── Phase H: Productivity ─────────────────────────────────────────────
GOOGLE_CLIENT_SECRET=              # console.cloud.google.com → OAuth 2.0
GOOGLE_REDIRECT_URI=               # Must match OAuth consent screen
MS_GRAPH_TOKEN=                    # Microsoft Graph delegated token (set after OAuth)
DROPBOX_ACCESS_TOKEN=              # dropbox.com → App Console → Token

# ─── Phase I: Commerce ─────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=              # mystore.myshopify.com (no https://)
SHOPIFY_ADMIN_TOKEN=               # Shopify Admin → Apps → Private apps → Admin API key
WOOCOMMERCE_URL=                   # https://your-wordpress-site.com
WOOCOMMERCE_KEY=                   # WooCommerce → Settings → REST API → Consumer Key
WOOCOMMERCE_SECRET=                # Consumer Secret
WORDPRESS_URL=                     # https://your-wordpress-site.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=            # User → Application Passwords

# ─── Phase J: Creative ─────────────────────────────────────────────────
FIGMA_ACCESS_TOKEN=                # figma.com → Account Settings → Personal access tokens
CANVA_CLIENT_ID=                   # canva.dev → Your integrations
CANVA_CLIENT_SECRET=
CANVA_API_KEY=                     # Canva Connect API key

# ─── Phase K: Automation ───────────────────────────────────────────────
ZAPIER_WEBHOOK_URL=                # Zapier → Zap → Trigger: Webhooks by Zapier → Catch Hook URL
MAKE_API_KEY=                      # Make (Integromat) → Profile → API Key
MAKE_WEBHOOK_URL=                  # Make → Scenario → Webhook URL
N8N_HOST=                          # https://your-n8n-instance.com
N8N_API_KEY=                       # n8n → Settings → API Key

# ─── Phase L: Monitoring (additions) ───────────────────────────────────
DATADOG_API_KEY=                   # app.datadoghq.com → Organization Settings → API Keys
DATADOG_APP_KEY=                   # Application Key (optional — for management API)
DATADOG_SITE=datadoghq.com         # EU users: datadoghq.eu
UPTIMEROBOT_API_KEY=               # uptimerobot.com → My Settings → API Settings

# ════════════════════════════════════════════════════════════════════════
# PRODUCTION MISSION 6 — Closed Beta Operations (RC-1)
# Required for: email verification, beta invite flow, billing subscriptions,
# Telegram crash alerts, and beta user cap enforcement.
# ════════════════════════════════════════════════════════════════════════

# ─── Email (RC-1 — required for email verification + password reset) ────
# [REQUIRED for beta] resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Beta User Cap ─────────────────────────────────────────────────────
# Hard limit on registered beta accounts (default: 50). Override here or in code.
# [OPTIONAL] Leave blank to use the hardcoded default of 50.
BETA_MAX_USERS=50

# ─── Razorpay Subscription Plans (RC-1) ────────────────────────────────
# [REQUIRED for paid upgrades] Razorpay Dashboard → Products → Plans
# Create monthly plans matching PLAN_PRICES_INR in closedBeta.cjs
RAZORPAY_PLAN_ID_STARTER=plan_your_starter_plan_id
RAZORPAY_PLAN_ID_GROWTH=plan_your_growth_plan_id
RAZORPAY_PLAN_ID_ENTERPRISE=plan_your_enterprise_plan_id

# ─── Telegram Operator Alerts ──────────────────────────────────────────
# [OPTIONAL] Chat ID to receive crash alerts and EOD summaries.
# Get your chat ID: https://t.me/userinfobot
TELEGRAM_OPERATOR_CHAT_ID=your_telegram_chat_id_here
