# Jarvis React App — Environment Variables
# Copy to .env and fill in values

# Backend API URL
# - Desktop (Electron): leave as default (localhost)
# - Web browser: set to your server's public URL or leave as localhost
# - Android/Mobile: set to your machine's local network IP (find with: ifconfig | grep inet)
#   Example: http://192.168.1.42:3000
REACT_APP_API_URL=http://localhost:5000

# React dev server port (must match Electron's mainWindow.loadURL)
 REACT_APP_DEV_SERVER_PORT=5000