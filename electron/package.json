{
  "name": "jarvis-desktop",
  "version": "1.0.0",
  "description": "JARVIS - Self-Evolving AI Assistant Desktop Application",
  "main": "main.cjs",
  "homepage": "./",
  "author": "JARVIS Team",
  "license": "MIT",
  "scripts": {
    "dev": "PORT=3001 react-scripts start",
    "build": "react-scripts build",
    "start": "electron .",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "electron-dev": "cross-env ELECTRON_START_URL=http://localhost:3001 electron .",
    "build-app": "npm run build && electron-builder --publish=never",
    "build-app-mac": "npm run build && electron-builder -m",
    "build-app-linux": "npm run build && electron-builder -l",
    "build-app-win": "npm run build && electron-builder -w",
    "lint": "eslint src",
    "test": "react-scripts test --watchAll=false",
    "mobile:sync": "npm run build && npx cap copy android",
    "mobile:open": "npx cap open android",
    "mobile:build": "npm run build && npx cap copy android && npx cap open android"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "electron-is-dev": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "react-speech-recognition": "^4.0.1",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^7.0.1",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.jarvis.desktop",
    "productName": "JARVIS",
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "icon": "electron/assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/assets/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/assets/icon.ico"
    }
  }
}
